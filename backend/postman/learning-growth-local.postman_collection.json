{
  "info": {
    "_postman_id": "c9e0c6db-9ca0-4cbf-bf19-11d03e0d4e2f",
    "name": "Mentors Learning-Growth Local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Local dev flow for testing the unified learning -> growth integration on top of the main curriculum."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Issue Fresh Dev Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dev token issued', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('token', body.access_token);",
              "pm.collectionVariables.set('userId', String(body.user.id));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"postman+{{$timestamp}}@local.test\",\n  \"nickname\": \"postman-local\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/dev-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "dev-token"
          ]
        }
      }
    },
    {
      "name": "2. Get Current User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('current user fetched', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('user matches saved token', function () {",
              "  pm.expect(String(body.id)).to.eql(pm.collectionVariables.get('userId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "3. Growth Progress (Initial)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('initial growth progress fetched', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('fresh user starts at T1', function () {",
              "  pm.expect(body.current_tier).to.eql('T1');",
              "  pm.expect(body.progress_percent).to.eql(0);",
              "  pm.expect(body.eligible_for_promotion).to.eql(false);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/growth/me/progress",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "growth",
            "me",
            "progress"
          ]
        }
      }
    },
    {
      "name": "4. Learning Quizzes (Current Tier)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('current tier quizzes fetched', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('fresh user receives T1 learning concepts', function () {",
              "  pm.expect(body.tier).to.eql('T1');",
              "  pm.expect(body.quizzes).to.have.length(8);",
              "  pm.expect(body.quizzes.map((quiz) => quiz.concept_id)).to.eql([1, 2, 3, 4, 5, 6, 7, 8]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
