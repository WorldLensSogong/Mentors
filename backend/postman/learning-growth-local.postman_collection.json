        "url": {
          "raw": "{{baseUrl}}/api/learning/me/quizzes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "learning",
            "me",
            "quizzes"
          ]
        }
      }
    },
