# 환경 — dev / prod
ENV=dev

# DB (docker-compose 기본값)
# - driver: 운영/Linux/Mac은 asyncpg 권장. Windows + Docker Desktop은 psycopg 권장
#   (asyncpg가 ProactorEventLoop·IPv6 매핑과 마찰을 일으킴 — 자세한 건 SETUP.md 참고)
# - host: localhost는 Windows에서 IPv6(::1) 우선이라 컨테이너 도달 실패할 수 있음 → 127.0.0.1 명시
DATABASE_URL=postgresql+psycopg://mentors:mentors@127.0.0.1:5432/mentors

# Redis (cache + Pub/Sub broker)
REDIS_URL=redis://127.0.0.1:6379/0

# JWT (32+ 바이트 랜덤 권장 — 예시값 절대 그대로 쓰지 말 것)
JWT_SECRET=change-me-to-at-least-32-bytes-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth (Google Cloud Console에서 발급)
# dev에서 OAuth 거치기 싫으면 POST /auth/dev-token 사용 (ENV=dev에서만 활성)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# LLM — provider 선택 + API 키
# ─────────────────────────────────────────────────────────────────────────────
# 전역 디폴트 provider — openai | anthropic | google
LLM_PROVIDER=openai

# use_case별 provider override (코어 디폴트: content→openai, debate→google).
# 디폴트 provider의 키가 비어 있으면 자동으로 LLM_PROVIDER로 fallback.
#   CONTENT_LLM_PROVIDER — 뉴스 파이프라인(번역/요약/키워드 추출/투자관련도 분석)에 사용
#   DEBATE_LLM_PROVIDER  — 멘토 토론에 사용
CONTENT_LLM_PROVIDER=openai
DEBATE_LLM_PROVIDER=

# 임베딩 provider — openai | google (미설정 시 LLM_PROVIDER 따라감)
# ⚠️ 변경 시 기존 Chroma collection 재생성 필요 (OpenAI=1536d, Gemini=3072d)
EMBEDDING_PROVIDER=

# API 키 (선택된 provider에 맞는 것만 채워 넣으면 됨)
#   파이프라인용 OpenAI 키 — content_llm_provider=openai일 때 뉴스 수집 후
#   번역·요약·신뢰도/관련도 분석에 사용됨. 비워두면 LLM_PROVIDER로 fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_STREAM_TIMEOUT_S=60

# ─────────────────────────────────────────────────────────────────────────────
# News collectors
# ─────────────────────────────────────────────────────────────────────────────
# Finnhub 시세/뉴스 (newspipeline source)
FINNHUB_API_KEY=
DART_API_KEY=

# Naver News Search API (토론 근거 뉴스 검색)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# auto schedular
MAX_P0_PER_TICK=15
MAX_P1_PER_TICK=12
MAX_P2_PER_TICK=8
MAX_P3_PER_TICK=5
MAX_KEYWORDS_PER_TICK=40
COMPANIES_PER_KEYWORD=5

# 뉴스 신뢰도 임계값 (pipeline_utils.reliability_score 산출값 기준 0~100)
#   VISIBLE:    이 점수 이상이어야 사용자 노출 (/news 피드)
#   RAG:        이 점수 이상이어야 AI 처리 + RAG 인덱싱 (LLM 비용)
#   SEARCH_MIN: /news/search 결과 최저값 (검색 풀 조정 — AI 비용 무관)
# 권장: VISIBLE >= RAG >= SEARCH_MIN. RAG/SEARCH_MIN 분리로 비용/노출 독립 튜닝.
CONTENT_VISIBLE_THRESHOLD=50
CONTENT_RAG_THRESHOLD=40
CONTENT_SEARCH_MIN_SCORE=40

# Vector store
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001

# FCM (v1.1) — 서비스 계정 JSON 파일 경로. dev에서 푸시 끄려면 빈 값 유지
FCM_CREDENTIALS_PATH=

# APScheduler (v1.1)
SCHEDULER_TIMEZONE=Asia/Seoul
# SCHEDULER_JOBSTORE_URL=  # 비워두면 DATABASE_URL 사용

# Market data cache (debate topic resolution)
MARKET_DATA_REFRESH_ENABLED=false
MARKET_DATA_REFRESH_INTERVAL_MINUTES=360
MARKET_DATA_DISCOVERY_ENABLED=false
MARKET_DATA_SEED_SYMBOLS=AAPL,MSFT,NVDA,TSLA,GOOGL,META,AMZN
MARKET_DATA_SEED_KOREAN_QUERIES=삼성전자,SK하이닉스,현대차,네이버,카카오
